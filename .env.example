# ===================================================
# .env.example - Proyecto Copa FutBotMX
# Plantilla versionada del .env. El script bootstrap_data copia este archivo a
# .env si no existe (no sobreescribe uno existente). Valores fijos: NO hay rutas
# de host (modelo de archivos reales) ni secretos.
# ===================================================

# Nombre del directorio de trabajo del proyecto DENTRO del contenedor.
# Se usa como WORKDIR y como punto de montaje del workspace. No asumir /app.
CONTAINER_WORKSPACE_DIR=futbot

# Datos pesados: NO se configuran rutas de host aqui. La convencion es que los
# videos y el modelo SAM3 viven como ARCHIVOS REALES en el repo, bajo data/raw y
# assets/sam3 (git-ignored). El bind-mount del workspace los lleva al contenedor.
# Para poblarlos usa el script: python -m src.bootstrap_data

# Ruta relativa (bajo configs/) del archivo de configuracion que se cargara.
CONFIG_FILENAME=01_yolo_sam3_config.json
